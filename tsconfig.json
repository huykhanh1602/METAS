{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2022",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "jsx": "preserve",
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "skipLibCheck": true,
        "allowJs": true,
        "noEmit": true,
        "incremental": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": ["next-env.d.ts", "src/**/*", ".next/types/**/*.d.ts", ".next/types/**/*.ts"],
    "exclude": ["node_modules"]
}
